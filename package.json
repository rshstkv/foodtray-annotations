{
  "name": "assisted-orders-nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "supabase migration up",
    "db:reset": "supabase db reset && npm run db:seed-users",
    "db:seed-users": ".venv/bin/python3 scripts/seed_users.py",
    "db:seed-users:staging": ".venv/bin/python3 scripts/seed_users.py --staging",
    "db:seed-users:prod": ".venv/bin/python3 scripts/seed_users.py --production",
    "ingest:load": ".venv/bin/python3 scripts/ingest/cli.py load --with-qwen",
    "ingest:load:staging": ".venv/bin/python3 scripts/ingest/cli.py --staging load --with-qwen",
    "ingest:load:staging:1000": ".venv/bin/python3 scripts/ingest/cli.py --staging load --with-qwen --limit 1000 --source \"/Users/romanshestakov/Downloads/RRS_Dataset 2\"",
    "ingest:load:production": ".venv/bin/python3 scripts/ingest/cli.py --production load --with-qwen",
    "ingest:load:production:100": ".venv/bin/python3 scripts/ingest/cli.py --production load --with-qwen --limit 3650 --source \"/Users/romanshestakov/Downloads/RRS_Dataset 2\"",
    "ingest:load:production:5k": ".venv/bin/python3 scripts/ingest/cli.py --production load --with-qwen --limit 5000 --source \"/Users/romanshestakov/Downloads/RRS_Dataset 2\"",
    "ingest:load:production:+200": ".venv/bin/python3 scripts/ingest/cli.py --production load --with-qwen --limit 4300 --source \"/Users/romanshestakov/Downloads/RRS_Dataset 2\"",
    "ingest:load-qwen": ".venv/bin/python3 scripts/ingest/cli.py load-qwen",
    "ingest:reset": ".venv/bin/python3 scripts/ingest/cli.py reset",
    "ingest:reset:staging": ".venv/bin/python3 scripts/ingest/cli.py --staging reset",
    "ingest:status": ".venv/bin/python3 scripts/ingest/cli.py status",
    "ingest:status:staging": ".venv/bin/python3 scripts/ingest/cli.py --staging status",
    "ingest:status:production": ".venv/bin/python3 scripts/ingest/cli.py --production status",
    "ingest:all": "npm run ingest:load -- --limit 100 && npm run ingest:load-qwen",
    "db:load-staging": "bash scripts/load-dump-to-staging.sh",
    "detection:load": ".venv/bin/python scripts/ingest_detection/cli.py load",
    "detection:load:staging": ".venv/bin/python scripts/ingest_detection/cli.py --staging load",
    "detection:load:production": ".venv/bin/python scripts/ingest_detection/cli.py --production load",
    "prepare": "husky"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toast": "^1.2.15",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.58.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.544.0",
    "next": "^15.5.14",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
